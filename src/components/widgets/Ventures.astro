---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { CallToAction, Widget } from '~/types';
import Headline from '~/components/ui/Headline.astro';

interface Props extends Widget {
  title?: string;
  subtitle?: string;
  tagline?: string;
  callToAction?: CallToAction;
  actions?: string | CallToAction[];
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  actions = await Astro.slots.render('actions'),

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <div
    class="max-w-5xl mx-auto text-center p-6 rounded-md shadow-xl dark:shadow-none dark:border dark:border-slate-600"
  >
    <Headline
      title={title}
      subtitle={subtitle}
      tagline={tagline}
      classes={{
        container: 'mb-0 md:mb-0',
        title: 'text-4xl md:text-4xl font-bold tracking-tighter mb-0 font-heading',
        subtitle: 'text-xl text-muted dark:text-slate-400',
      }}
    />
    {
      actions && (
        <div class="m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4">
          {Array.isArray(actions) ? (
            actions.map(() => (
              <div class="flex w-full sm:w-auto">
                <div class="bg-white py-24 sm:py-32">
                  <div class="mx-auto max-w-7xl px-6 lg:px-8">
                    <div class="mx-auto mt-0 grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-10 sm:max-w-xl sm:grid-cols-6 sm:gap-x-10 lg:mx-0 lg:max-w-none lg:grid-cols-5">
                      <img
                        width="158"
                        height="48"
                        src="../src/assets/images/fk-logo.png"
                        alt=""
                        class="col-span-2 max-h-12 w-full object-contain lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/ssp-logo.png"
                        alt=""
                        class="col-span-2 max-h-12 w-full object-contain lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/signify-logo.png"
                        alt=""
                        class="col-span-2 max-h-12 w-full object-contain lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/eightten-logo.png"
                        alt=""
                        class="col-span-2 max-h-12 w-full object-contain sm:col-start-2 lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/timberlearn.jpg"
                        alt=""
                        class="col-span-2 max-h-12 w-full object-contain sm:col-start-2 lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/sanction-logo.png"
                        alt=""
                        class="col-span-2 max-h-12 w-full object-contain sm:col-start-2 lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/atn-logo2.png"
                        alt=""
                        class="col-span-2 col-start-2 max-h-12 w-full object-contain sm:col-start-auto lg:col-span-1"
                      />
                      <img
                        width="158"
                        height="48"
                        src="/src/assets/images/wsa-logo.png"
                        alt=""
                        class="col-span-2 col-start-2 max-h-12 w-full object-contain sm:col-start-auto lg:col-span-1"
                      />
                    </div>
                  </div>
                </div>
              </div>
            ))
          ) : (
            <Fragment set:html={actions} />
          )}
        </div>
      )
    }
  </div>
</WidgetWrapper>
