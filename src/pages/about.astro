---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import { headerData } from '~/navigation';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'About Josef Scarantino',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header {...headerData} isSticky />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero id="hero" title="Josef Scarantino" tagline="About">
    <Fragment slot="subtitle">
      Systems thinker, community-builder, &amp; accidental founder.<br />Currently building the shared transformation
      economy at <a href="https://forwardkind.com" class="text-accent font-semibold">Forwardkind</a>.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[]}
    image={{
      src: '~/assets/images/selfie.png',
      alt: 'Picture of Josef Scarantino',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <p>
        As a social innovation strategist, my work helps to design impactful, collaborative experiences where people and
        communities can fully participate and thrive. I'm also a serial entrepreneur and established founder coach with
        nearly 25 years of experience building entrepreneurial communities, startup ecosystems, and next generation
        impact leaders.
      </p>
      <br />
      <p>
        My work has reached thousands of students, entrepreneurs, and innovators across more than 50 countries and
        touched a wide variety of sectors, including workforce development, higher education, nonprofit, government,
        corporate innovation, and many others.
      </p>
      <br />
      <p>
        I'm currently building the transformation economy at <a
          href="https://forwardkind.com"
          target="_blank"
          class="text-accent">Forwardkind</a
        >, exploring how a shared-ownership cooperative model can contribute to cultivating collective human potential.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="History"
    items={[
      {
        title:
          'Founder & President <br /> <span class="font-normal"><a href="https://forwardkind.com" target="_blank" class="text-accent">Forwardkind Cooperative</a></span> <br /> <span class="text-sm font-normal">2025 - Present</span>',
        description: `Forwardkind is building a shared-ownership, regenerative ecosystem that multiplies human potential — expanding access to transformational work and amplifying the collective impact of purpose-driven people.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Founder <br /> <span class="font-normal"><a href="https://wckdlabs.com/" target="_blank" class="text-accent">WCKD Labs</a></span> <br /> <span class="text-sm font-normal">2025 - Present</span>',
        description: `Coming soon`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Founder <br /> <span class="font-normal"><a href="https://seedscalepartners.com/" target="_blank" class="text-accent">Seed Scale Partners</a></span> <br /> <span class="text-sm font-normal">2024 - Present</span>',
        description: `Seed Scale Partners delivers program design & management, ecosystem mapping, founder workshops, hackathons & pitch events, among other offerings. Most recent work is the <a href="https://rcedp.org/hca_lp" target="_blank">High Country Accelerator</a> in northwest Colorado.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Program Advisor <br /> <span class="font-normal"><a href="https://startupcolorado.org/" target="_blank" class="text-accent">Startup Colorado</a></span> <br /> <span class="text-sm font-normal">2024</span>',
        description: `Startup Colorado's mission is to demonstrate that rural entrepreneurship will ignite a culture of potential.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Head of Programs <br /> <span class="font-normal"><a href="https://allraise.org/" target="_blank" class="text-accent">All Raise</a></span> <br /> <span class="text-sm font-normal">2022 - 2023</span>',
        description: `All Raise is on a mission to accelerate the success of women and nonbinary investors, reshaping culture, capital flows, and decision-making power within venture capital.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Program Manager <br /> <span class="font-normal"><a href="https://www.hubspot.com/ventures" target="_blank" class="text-accent">HubSpot Ventures</a></span> <br /> <span class="text-sm font-normal">2022</span>',
        description: `HubSpot Ventures invests in early- and growth-stage software companies with the potential to deliver unique value to HubSpot's customer base.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Senior Program Manager <br /> <span class="font-normal"><a href="https://techstars.com" target="_blank" class="text-accent">Techstars</a></span> <br /> <span class="text-sm font-normal">2019 - 2022</span>',
        description: `Founded in 2006, Techstars is on a mission to invest in startups to enable more capital to flow to more entrepreneurs around the world in order to deliver exceptional returns to investors. Techstars does this by operating accelerator programs and venture capital funds, as well as by connecting startups, investors, corporations, and cities to help build thriving startup communities.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'CEO & Co-Founder <br /> <span class="font-normal text-accent">EightTen</span> <br /> <span class="text-sm font-normal">2016 - 2019</span>',
        description: `EightTen was an edtech startup dedicated to increasing labor force participation of people with disabilities through soft skills training.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Director of Social Enterprise <br /> <span class="font-normal text-accent">Community Resource Center</span> <br /> <span class="text-sm font-normal">2017 - 2018</span>',
        description: `CRC creates opportunities, tools, and strategies to develop nonprofits and community groups to strengthen Colorado.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Director of Life Labs <br /> <span class="font-normal text-accent">United Cerebral Palsy</span> <br /> <span class="text-sm font-normal">2012 - 2016</span>',
        description: `Mission to promote the independence and inclusion of people with cerebral palsy, intellectual, developmental, and other disabilities through a network of affiliates and partnerships.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Founder <br /> <span class="font-normal text-accent">African Tech Network</span> <br /> <span class="text-sm font-normal">2010</span>',
        description: `African Tech Network (ATN) served African technologists through creating economic opportunity, community, and continuing education.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Founder <br /> <span class="font-normal text-accent">webstartAfrica</span> <br /> <span class="text-sm font-normal">2009</span>',
        description: `Webstart Africa focused on increasing access to turn-key technology stacks for emerging African entrepreneurs.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Creative Director <br /> <span class="font-normal text-accent">GovTrends</span> <br /> <span class="text-sm font-normal">2006 - 2009</span>',
        description: `GovTrends was a web development and design studio providing services to government entities and representatives and Fortune 500 companies.`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Fragment>
    <Steps
      id="resume"
      title="Education"
      items={[
        {
          title: `Master of Arts in International Education & Human Development <br /> <span class="font-normal">George Washington University</span>`,
          icon: 'tabler:school',
        },
        {
          title: `Startup Investor School <br /> <span class="font-normal">Y Combinator</span>`,
          icon: 'tabler:school',
        },
        {
          title: `Venture Associate Program <br /> <span class="font-normal">Republic</span>`,
          icon: 'tabler:school',
        },
        {
          title: `Venture Scout Program <br /> <span class="font-normal">Hawke Ventures</span>`,
          icon: 'tabler:school',
        },
      ]}
      classes={{ container: 'max-w-3xl' }}
    />
  </Fragment>

  <!-- Brands Widget ****************** -->

  <Brands
    title="Volunteering"
    subtitle="A sampling of brands where I've volunteered."
    icons={[]}
    images={[
      {
        src: '../assets/images/cdle-logo.png',
        alt: 'Colorado Disability Opportunity Office',
      },
      {
        src: '../assets/images/denver-art-museum-logo.png',
        alt: 'Denver Art Museum',
      },
      {
        src: '../assets/images/gildre-logo.png',
        alt: 'Gildre',
      },

      {
        src: '../assets/images/startout-logo.png',
        alt: 'StartOut',
      },
      {
        src: '../assets/images/truist-foundation-logo.png',
        alt: 'Truist Foundation',
      },
      {
        src: '../assets/images/black-ambition-logo.png',
        alt: 'Black Ambition Prize',
      },
      {
        src: '../assets/images/access-mode-logo.png',
        alt: 'Access Mode',
      },
      {
        src: '../assets/images/scale-ventures-logo.jpg',
        alt: 'Scale Ventures',
      },
      {
        src: '../assets/images/breakthrough-logo.png',
        alt: 'Breakthrough',
      },
      {
        src: '../assets/images/capital-startup-capital-logo.jpeg',
        alt: 'Capital Startup Capital 2024',
      },
      {
        src: '../assets/images/idea-gto-logo.png',
        alt: 'Idea GTO',
      },
      {
        src: '../assets/images/manos-accelerator-logo.png',
        alt: 'Manos Accelerator',
      },
      {
        src: '../assets/images/draper-university-logo.jpeg',
        alt: 'Draper University',
      },
      {
        src: '../assets/images/zane-access-logo.png',
        alt: 'Zane Access',
      },
      {
        src: '../assets/images/scalenl-accelerator-logo.png',
        alt: 'ScaleNL Accelerator',
      },
      {
        src: '../assets/images/denver-logo.png',
        alt: 'Denver Global Landing Pad',
      },
      {
        src: '../assets/images/extreme-tech-challenge-logo.png',
        alt: 'Extreme Tech Challenge',
      },
      {
        src: '../assets/images/verizon-forward-for-good-logo.jpeg',
        alt: 'Verizon Forward for Good Accelerator',
      },
      {
        src: '../assets/images/startup-grind-logo.png',
        alt: 'Startup Grind',
      },
      {
        src: '../assets/images/envision-accelerator-logo.png',
        alt: 'Envision Accelerator',
      },
      {
        src: '../assets/images/gsv-logo.png',
        alt: 'Global Silicon Valley',
      },
      {
        src: '../assets/images/chafee-county-edc-logo.png',
        alt: 'Chafee County EDC',
      },
      {
        src: '../assets/images/blackstone-launchpad-logo.png',
        alt: 'Blackstone Launchpad',
      },
      {
        src: '../assets/images/ubuffalo-colab-logo.png',
        alt: 'UBuffalo CoLab',
      },
      {
        src: '../assets/images/visible-hands-logo.jpeg',
        alt: 'Visible Hands',
      },
      {
        src: '../assets/images/regis-university-logo.jpg',
        alt: 'Regis University Innovation Challenge',
      },
    ]}
  />
</Layout>
